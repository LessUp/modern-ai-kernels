{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build with full debugging symbols",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CUDA_FLAGS": "-G -lineinfo -Xcompiler -Wall",
                "TC_BUILD_TESTS": "ON",
                "TC_BUILD_BENCHMARKS": "OFF"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Optimized release build",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CUDA_ARCHITECTURES": "70;75;80;86;89;90",
                "CMAKE_CUDA_FLAGS": "-O3 --use_fast_math -Xcompiler -O3",
                "TC_BUILD_TESTS": "ON",
                "TC_BUILD_BENCHMARKS": "ON"
            }
        },
        {
            "name": "dev",
            "displayName": "Dev",
            "description": "Faster single-architecture CUDA development build",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_CUDA_ARCHITECTURES": "75",
                "CMAKE_CUDA_FLAGS": "-lineinfo -Xcompiler -O2",
                "TC_BUILD_TESTS": "ON",
                "TC_BUILD_BENCHMARKS": "OFF",
                "TC_BUILD_PYTHON": "ON"
            }
        },
        {
            "name": "python-dev",
            "displayName": "Python Dev",
            "description": "Single-architecture CUDA build focused on Python bindings",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_CUDA_ARCHITECTURES": "75",
                "CMAKE_CUDA_FLAGS": "-lineinfo -Xcompiler -O2",
                "TC_BUILD_TESTS": "OFF",
                "TC_BUILD_BENCHMARKS": "OFF",
                "TC_BUILD_PYTHON": "ON"
            }
        },
        {
            "name": "profile",
            "displayName": "Profile",
            "description": "Release build with profiling symbols for Nsight",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_CUDA_FLAGS": "-O3 -lineinfo --generate-line-info -Xcompiler -O3",
                "TC_BUILD_TESTS": "ON",
                "TC_BUILD_BENCHMARKS": "ON"
            }
        },
        {
            "name": "ci",
            "displayName": "CI",
            "description": "Configuration for CI/CD pipelines",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CUDA_FLAGS": "-O3",
                "TC_BUILD_TESTS": "ON",
                "TC_BUILD_BENCHMARKS": "ON",
                "TC_BUILD_PYTHON": "OFF"
            }
        },
        {
            "name": "cpu-smoke",
            "displayName": "CPU Smoke",
            "description": "CPU-only configure/install smoke validation",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "TC_ENABLE_CUDA": "OFF",
                "TC_BUILD_TESTS": "OFF",
                "TC_BUILD_BENCHMARKS": "OFF",
                "TC_BUILD_PYTHON": "OFF",
                "TC_BUILD_DOCS": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "dev",
            "configurePreset": "dev"
        },
        {
            "name": "python-dev",
            "configurePreset": "python-dev"
        },
        {
            "name": "profile",
            "configurePreset": "profile"
        },
        {
            "name": "ci",
            "configurePreset": "ci"
        },
        {
            "name": "cpu-smoke",
            "configurePreset": "cpu-smoke"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": {
                "outputOnFailure": true,
                "verbosity": "verbose"
            }
        },
        {
            "name": "release",
            "configurePreset": "release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "dev",
            "configurePreset": "dev",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ci",
            "configurePreset": "ci",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error"
            }
        }
    ]
}
